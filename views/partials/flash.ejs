<%
// Flash messages are "one request" feedback after redirects,
// keeping UX responsive without re-submitting forms.
if (errorMsg && errorMsg.length > 0) { 
%>
    <div class="alert-danger">
        <%= errorMsg %> 
    </div>
<% } %>

<%
if (successMsg && successMsg.length > 0) { 
%>
    <div class="alert-success">
        <%= successMsg %> 
    </div>
<% } %>